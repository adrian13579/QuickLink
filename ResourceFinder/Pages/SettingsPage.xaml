<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ResourceFinder.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ResourceFinder.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="24,20" Spacing="20" MaxWidth="640">

            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button
                    Click="Back_Click"
                    ToolTipService.ToolTip="Back"
                    CornerRadius="8"
                    Width="36"
                    Height="36"
                    Padding="0">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" />
                </Button>
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Settings" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Data File Path card -->
            <Border
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border
                            Width="36"
                            Height="36"
                            CornerRadius="8"
                            Background="{ThemeResource AccentFillColorSecondaryBrush}">
                            <FontIcon
                                Glyph="&#xE8B7;"
                                FontSize="18"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Data File Path" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock
                                Text="JSON file where resources are stored. Takes effect after restarting."
                                Opacity="0.6"
                                TextWrapping="Wrap"
                                Style="{StaticResource CaptionTextBlockStyle}" />
                        </StackPanel>
                    </StackPanel>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="DataFilePathBox"
                            FontFamily="Consolas"
                            PlaceholderText="Path to resources.json"
                            CornerRadius="6" />
                        <Button
                            Grid.Column="1"
                            Content="Browse…"
                            Click="Browse_Click"
                            VerticalAlignment="Center"
                            CornerRadius="6" />
                    </Grid>
                </StackPanel>
            </Border>

            <Button
                Style="{StaticResource AccentButtonStyle}"
                CornerRadius="6"
                Click="Save_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE74E;" FontSize="13" />
                    <TextBlock Text="Save" />
                </StackPanel>
            </Button>

        </StackPanel>
    </ScrollViewer>
</Page>
