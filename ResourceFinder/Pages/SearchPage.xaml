<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QuickLink.Pages.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:QuickLink.Pages"
    xmlns:models="using:QuickLink.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <Style x:Key="DeprecatedTextStyle" TargetType="TextBlock">
            <Setter Property="TextDecorations" Value="Strikethrough" />
            <Setter Property="Opacity" Value="0.5" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Search bar -->
        <Grid Grid.Row="0" Margin="12,12,12,0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Input with embedded search icon -->
            <Grid>
                <TextBox
                    x:Name="SearchBox"
                    PlaceholderText="Search resources..."
                    Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    FontSize="14"
                    Height="40"
                    Padding="46,9,14,9"
                    CornerRadius="20"
                    KeyDown="SearchBox_KeyDown" />
                <FontIcon
                    Glyph="&#xE721;"
                    FontSize="14"
                    Opacity="0.5"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="17,0,0,0"
                    IsHitTestVisible="False" />
            </Grid>

            <Button
                Grid.Column="1"
                Height="40"
                Width="40"
                ToolTipService.ToolTip="Settings"
                Click="Settings_Click"
                CornerRadius="20">
                <FontIcon Glyph="&#xE713;" FontSize="15" />
            </Button>
            <Button
                Grid.Column="2"
                Height="40"
                Width="40"
                ToolTipService.ToolTip="Add Resource"
                Click="AddResource_Click"
                Style="{StaticResource AccentButtonStyle}"
                CornerRadius="20">
                <FontIcon Glyph="&#xE710;" FontSize="15" />
            </Button>
        </Grid>

        <!-- Results list -->
        <ListView
            x:Name="ResultsList"
            Grid.Row="1"
            Visibility="{x:Bind local:SearchPage.BoolToVis(ViewModel.HasQuery), Mode=OneWay}"
            Margin="8,8,8,0"
            ItemsSource="{x:Bind ViewModel.Results}"
            SelectionMode="Single"
            IsItemClickEnabled="True"
            ItemClick="ResultsList_ItemClick"
            KeyDown="ResultsList_KeyDown">
            <ListView.KeyboardAccelerators>
                <KeyboardAccelerator Modifiers="Control" Key="Enter" Invoked="OpenInBrowser_Accelerator" />
            </ListView.KeyboardAccelerators>
            <ListView.ItemContainerTransitions>
                <TransitionCollection>
                    <AddDeleteThemeTransition />
                </TransitionCollection>
            </ListView.ItemContainerTransitions>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="10,6" />
                    <Setter Property="CornerRadius" Value="8" />
                    <Setter Property="Margin" Value="0,2" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:SearchResult">
                    <Grid ColumnSpacing="10" Padding="2,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="38" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Initial avatar -->
                        <Border
                            Width="34"
                            Height="34"
                            CornerRadius="8"
                            Background="{ThemeResource AccentFillColorSecondaryBrush}"
                            VerticalAlignment="Center">
                            <TextBlock
                                Text="{x:Bind local:SearchPage.GetInitial(Resource.Name)}"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>

                        <!-- Name · URL · Tags -->
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock
                                Text="{x:Bind Resource.Name}"
                                FontWeight="SemiBold"
                                TextTrimming="CharacterEllipsis"
                                Style="{x:Bind local:SearchPage.GetNameStyle(Resource.IsDeprecated)}" />
                            <TextBlock
                                Text="{x:Bind CurrentUrl}"
                                Opacity="0.6"
                                FontSize="12"
                                TextTrimming="CharacterEllipsis" />
                            <ItemsControl ItemsSource="{x:Bind Resource.Tags}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="4" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Border
                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="10"
                                            Padding="8,2"
                                            Margin="0,3,0,0">
                                            <TextBlock
                                                Text="{x:Bind}"
                                                FontSize="10"
                                                Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Badges + action buttons -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="6" HorizontalAlignment="Right">
                            <Border
                                Visibility="{x:Bind local:SearchPage.DeprecatedVisibility(Resource.IsDeprecated)}"
                                Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="8,2"
                                HorizontalAlignment="Right">
                                <TextBlock
                                    Text="deprecated"
                                    FontSize="10"
                                    Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                            </Border>
                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                                <Button
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    CornerRadius="6"
                                    ToolTipService.ToolTip="Copy URL"
                                    Click="CopyUrl_Click"
                                    CommandParameter="{x:Bind}">
                                    <SymbolIcon Symbol="Copy" />
                                </Button>
                                <Button
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    CornerRadius="6"
                                    ToolTipService.ToolTip="Open in browser"
                                    Click="OpenUrl_Click"
                                    CommandParameter="{x:Bind}">
                                    <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                                </Button>
                                <Button
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    CornerRadius="6"
                                    ToolTipService.ToolTip="Edit / View details"
                                    Click="ViewDetails_Click"
                                    CommandParameter="{x:Bind}">
                                    <SymbolIcon Symbol="Edit" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- No results state (searched but nothing matched) -->
        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="14"
            IsHitTestVisible="False"
            Visibility="{x:Bind local:SearchPage.BoolToVis(ViewModel.ShowNoResults), Mode=OneWay}">
            <FontIcon
                Glyph="&#xE721;"
                FontSize="52"
                Opacity="0.18"
                HorizontalAlignment="Center" />
            <TextBlock
                Text="No resources found"
                FontSize="14"
                Opacity="0.4"
                HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Idle state (empty input) -->
        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="14"
            IsHitTestVisible="False"
            Visibility="{x:Bind local:SearchPage.BoolToVis(ViewModel.ShowIdle), Mode=OneWay}">
            <FontIcon
                Glyph="&#xE721;"
                FontSize="52"
                Opacity="0.12"
                HorizontalAlignment="Center" />
            <TextBlock
                Text="Type to search resources"
                FontSize="14"
                Opacity="0.35"
                HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Footer with keyboard hints -->
        <Grid Grid.Row="2" Padding="14,6,14,10">
            <StackPanel Orientation="Horizontal" Spacing="14" HorizontalAlignment="Left" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                    <Border
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="6,2">
                        <TextBlock Text="↑↓" FontSize="10" Opacity="0.65" />
                    </Border>
                    <TextBlock Text="Navigate" FontSize="11" Opacity="0.45" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                    <Border
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="6,2">
                        <TextBlock Text="Enter" FontSize="10" Opacity="0.65" />
                    </Border>
                    <TextBlock Text="Copy URL" FontSize="11" Opacity="0.45" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                    <Border
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="6,2">
                        <TextBlock Text="Ctrl+Enter" FontSize="10" Opacity="0.65" />
                    </Border>
                    <TextBlock Text="Open in browser" FontSize="11" Opacity="0.45" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                    <Border
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="6,2">
                        <TextBlock Text="Esc" FontSize="10" Opacity="0.65" />
                    </Border>
                    <TextBlock Text="Hide" FontSize="11" Opacity="0.45" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Border
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="6,2">
                    <TextBlock Text="{x:Bind CurrentHotkey, Mode=OneTime}" FontSize="10" Opacity="0.65" />
                </Border>
                <TextBlock Text="Show window" FontSize="11" Opacity="0.45" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Floating notification -->
        <InfoBar
            x:Name="StatusBar"
            Grid.RowSpan="3"
            IsOpen="False"
            IsClosable="True"
            VerticalAlignment="Bottom"
            HorizontalAlignment="Center"
            MaxWidth="480"
            Margin="0,0,0,24" />
    </Grid>
</Page>
